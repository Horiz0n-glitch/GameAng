rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Quizzes: owners can manage, anyone can read
    match /quizzes/{quizId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || request.resource.data.userId == request.auth.uid);
    }

    // Sessions: anyone can read; only authenticated users (profe) can create/delete
    match /sessions/{sessionId} {
      allow read: if true;
      allow create, delete: if request.auth != null;
      // Allow profe to update session fields (status, currentQIndex, etc.)
      allow update: if request.auth != null;

      // Players: anyone can read (leaderboard); each student writes only their own doc
      match /players/{playerId} {
        allow read: if true;
        // Allow creation only if the uid in the document matches the requester
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid;
        // Allow updates only to the owner of that player document
        allow update: if request.auth != null
          && resource.data.uid == request.auth.uid;
        // Only the profe (session owner) can delete player docs
        allow delete: if request.auth != null;
      }
    }
  }
}
